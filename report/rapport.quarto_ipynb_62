    "import pandas as pd\n",
    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "import os\n",
    "from sklearn.model_selection import KFold, cross_val_score\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "\n",
    "# 1. L'ANTIDOTE : Chargement et calcul rapide de la Validation Croisée (cv_r2)\n",
    "df = pd.read_csv('../data/processed/cleaned_data_sample.csv')\n",
    "X = df.drop(columns=['mpg', 'mpg_category'], errors='ignore')\n",
    "y = df['mpg']\n",
    "\n",
    "rf_model = RandomForestRegressor(n_estimators=100, random_state=42)\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=42)\n",
    "cv_r2 = cross_val_score(rf_model, X, y, cv=kf, scoring='r2')\n",
    "r2_mean = cv_r2.mean()\n",
    "\n",
    "# 2. Préparation des labels\n",
    "fold_labels = [f'Fold {i+1}' for i in range(5)]\n",
    "\n",
    "# 3. Création du graphique interactif (Barres)\n",
    "fig = go.Figure()\n",
    "\n",
    "fig.add_trace(go.Bar(\n",
    "    x=fold_labels,\n",
    "    y=cv_r2,\n",
    "    marker_color='#3b82f6',                       # Le beau bleu moderne\n",
    "    text=[f\"{val:.3f}\" for val in cv_r2],         # Les valeurs affichées sur les barres\n",
    "    textposition='auto',                          # Place les chiffres intelligemment\n",
    "    name='Score du Fold',\n",
    "    hovertemplate=\"<b>%{x}</b><br>Score R² : %{y:.3f}<extra></extra>\"\n",
    "))\n",
    "\n",
    "# 4. Ajout de la Ligne Rouge de Moyenne\n",
    "fig.add_hline(\n",
    "    y=r2_mean, \n",
    "    line_dash=\"dash\", \n",
    "    line_color=\"#ef4444\", \n",
    "    annotation_text=f\"Moyenne = {r2_mean:.3f}\", \n",
    "    annotation_position=\"top right\"\n",
    ")\n",
    "\n",
    "# 5. Mise en page globale\n",
    "fig.update_layout(\n",
    "    title_text=\"<b>Score R² par Fold — Validation Croisée (K-Fold K=5)</b>\",\n",
    "    title_font_size=16,\n",
    "    xaxis_title=\"Plis de validation (Folds)\",\n",
    "    yaxis_title=\"Coefficient de détermination (R²)\",\n",
    "    yaxis_range=[0.7, 1.0],                       # Maintient votre échelle d'origine\n",
    "    template=\"plotly_white\",                       # Le thème sombre du dashboard\n",
    "    height=500\n",
    ")\n",
    "\n",
    "# 6. Sauvegarde en format Web Interactif (.html)\n",
    "output_dir = '../data/processed'\n",
    "os.makedirs(output_dir, exist_ok=True)\n",
    "html_path = os.path.join(output_dir, 'cross_validation.html')\n",
    "fig.write_html(html_path)\n",
    "\n",
    "print(f\"✅ Graphique interactif sauvegardé : {html_path}\")\n",
    "\n",
    "# Affichage interactif\n",
    "fig.show()"
   ]
